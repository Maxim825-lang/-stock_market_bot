# ── Обязательно ──────────────────────────────────────────────────────────────
# Получите токен от @BotFather в Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Необязательно (новости) ───────────────────────────────────────────────────
# Получите бесплатно на https://newsapi.org/register
# Если не указан, бот будет работать без новостей
NEWS_API_KEY=optional_news_api_key_here

# ── Необязательно (AI-анализ) ─────────────────────────────────────────────────
# Получите на https://platform.openai.com/api-keys
# Если не указан, используется встроенный rule-based анализ
OPENAI_API_KEY=optional_openai_api_key_here
